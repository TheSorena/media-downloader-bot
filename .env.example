# ===========================================
# تنظیمات ربات تلگرام
# ===========================================

# توکن ربات از @BotFather
BOT_TOKEN=

# آیدی ادمین‌ها (با کاما جدا کنید)
ADMIN_IDS=7696465274

# ===========================================
# دیتابیس MongoDB
# ===========================================
MONGODB_URI=mongodb://localhost:27017/media_downloader

# ===========================================
# محدودیت‌ها (به مگابایت)
# ===========================================
FREE_DAILY_QUOTA_MB=5120
FREE_MAX_FILE_MB=2048
PREMIUM_MAX_FILE_MB=2000

# ===========================================
# دایرکتوری دانلود
# ===========================================
DOWNLOAD_DIR=/tmp/downloads

# ===========================================
# cobalt API
# ===========================================
COBALT_API_URL=http://localhost:9000

# ===========================================
# درگاه پرداخت BluePal
# ===========================================
BLUEPAL_API_KEY=
BLUEPAL_CALLBACK_URL=https://your-domain.com/payment/success

# ===========================================
# کانال اجباری
# ===========================================
FORCE_JOIN_CHANNEL=@yourchannel
FORCE_JOIN_LINK=https://t.me/yourchannel

# ===========================================
# پورت وبهوک + سرور
# ===========================================
PORT=3000

# ===========================================
# محیط اجرا
# ===========================================
NODE_ENV=production

# ===========================================
# کوکی‌ها (اختیاری)
# ===========================================
COOKIE_FILE=
