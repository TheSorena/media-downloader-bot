# توکن ربات از @BotFather
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# api_id و api_hash از https://my.telegram.org (برای Local Bot API)
TELEGRAM_API_ID=1234567
TELEGRAM_API_HASH=abcdef1234567890abcdef1234567890

# آیدی ادمین‌ها (با کاما جدا کنید)
ADMIN_IDS=123456789

# ===========================================
# محدودیت‌ها (به مگابایت)
# ===========================================
FREE_DAILY_QUOTA_MB=5120
FREE_MAX_FILE_MB=2048
PREMIUM_MAX_FILE_MB=2000

# ===========================================
# درگاه پرداخت BluePal (فاز بعدی)
# ===========================================
BLUEPAL_API_KEY=
BLUEPAL_CALLBACK_URL=

# ===========================================
# کانال اجباری (فاز بعدی)
# ===========================================
FORCE_JOIN_CHANNEL=@yourchannel
FORCE_JOIN_LINK=https://t.me/yourchannel
